{
  "info": {
    "_postman_id": "7409f1d5-f304-42ef-b808-developer-landing-api",
    "name": "Developer Landing API",
    "description": "FastAPI contact backend: validation, AI analysis/fallback, SMTP, rate limiting, health and metrics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "postman-demo-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status is ok or degraded', () => pm.expect(['ok', 'degraded']).to.include(body.status));",
                  "pm.test('checks are present', () => pm.expect(body.checks).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          }
        },
        {
          "name": "Metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('no PII flag', () => pm.expect(body.metadata.contains_personal_data).to.eql(false));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "metrics"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Create contact - success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('success contract', () => pm.expect(body.success).to.eql(true));",
                  "pm.test('AI result exists', () => pm.expect(body.ai).to.be.an('object'));",
                  "pm.test('delivery exists', () => pm.expect(body.delivery).to.be.an('object'));",
                  "pm.test('request ID echoed', () => pm.expect(pm.response.headers.get('X-Request-ID')).to.eql(body.request_id));",
                  "pm.test('rate limit headers exist', () => pm.expect(pm.response.headers.has('X-RateLimit-Limit')).to.eql(true));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Иван Иванов\",\n  \"phone\": \"+7 999 123-45-67\",\n  \"email\": \"ivan@example.com\",\n  \"comment\": \"Хочу обсудить разработку интернет-магазина, спасибо!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/contact",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "contact"
              ]
            }
          }
        },
        {
          "name": "Create contact - validation error",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 422', () => pm.response.to.have.status(422));",
                  "const body = pm.response.json();",
                  "pm.test('validation error code', () => pm.expect(body.error.code).to.eql('validation_error'));",
                  "pm.test('raw input is not reflected', () => pm.expect(JSON.stringify(body.error.details)).to.not.include('bad-email'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"1\",\n  \"phone\": \"call-me\",\n  \"email\": \"bad-email\",\n  \"comment\": \" \"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/contact",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "contact"
              ]
            }
          }
        }
      ]
    }
  ]
}
